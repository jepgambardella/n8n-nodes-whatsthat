{
  "name": "@jep182/n8n-nodes-whatsthat",
  "version": "0.2.2",
  "description": "n8n community nodes with embedded Baileys runtime for multi-session chat automation",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/jepgambardella/n8n-nodes-whatsthat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jepgambardella/n8n-nodes-whatsthat.git"
  },
  "bugs": {
    "url": "https://github.com/jepgambardella/n8n-nodes-whatsthat/issues"
  },
  "author": "jep182",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "baileys",
    "chat",
    "session",
    "automation"
  ],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/nodes/WhatsThatSession && cp nodes/WhatsThatSession/whatsthat.svg dist/nodes/WhatsThatSession/whatsthat.svg",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.82.0"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "n8n-core": "^1.82.0",
    "n8n-workflow": "^1.82.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WhatsThatRuntime.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WhatsThatSession/WhatsThatSession.node.js",
      "dist/nodes/WhatsThatTargets/WhatsThatTargets.node.js",
      "dist/nodes/WhatsThatMessage/WhatsThatMessage.node.js",
      "dist/nodes/WhatsThatTrigger/WhatsThatTrigger.node.js"
    ]
  }
}
